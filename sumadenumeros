# Programa que solicita números hasta que el usuario introduce 0
# y muestra la suma total utilizando un bucle while con un acumulador

acumulador = 0
while True:
    numero = int(input("Ingrese un número (0 para finalizar): "))
    if numero == 0:
        break
    acumulador += numero

print(f"La suma total es: {acumulador}")
